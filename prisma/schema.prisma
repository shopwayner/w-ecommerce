generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanCode {
  START
  MATRIX
  ENTERPRISE
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum OrganizationStatus {
  ACTIVE
  DISABLED
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum ConnectionRole {
  MATRIX
  BRANCH
  OTHER
}

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  ERROR
  DISCONNECTED
  PENDING
  DISABLED
}

enum BlingEnvironment {
  PRODUCTION
  SANDBOX
}

enum OAuthProvider {
  BLING
  MERCADOLIVRE
}

enum MarketplaceProvider {
  MERCADOLIVRE
  MAGALU
  SHOPEE
  SHOPEE_ADS
  AMAZON
  SHEIN
  TIKTOK_SHOP
}

enum ERPProvider {
  BLING
  OLIST
  OMIE
  CONTA_AZUL
  CUSTOM_API
}

enum MarketplaceCategoryProvider {
  MERCADO_LIVRE
  SHOPEE
  TIKTOK_SHOP
  AMAZON
  MAGALU
  OTHER
}

enum MarketplaceCategorySource {
  MANUAL
  INTERNAL_RULE
  MARKETPLACE_API
  IMPORTED
}

enum MarketplaceCategoryStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
}

enum MarketplaceProductAttributeSource {
  MANUAL
  PRODUCT_FIELD
  GTIN_CATALOG
  RULE
}

enum MarketplaceProductAttributeStatus {
  SUGGESTED
  CONFIRMED
  EMPTY
}

enum SyncDirection {
  MATRIX_TO_BRANCHES
  BRANCHES_TO_MATRIX
  BIDIRECTIONAL
  READ_ONLY
}

enum ConflictStrategy {
  MATRIX_WINS
  LATEST_WINS
  MANUAL_REVIEW
}

enum JobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELED
}

enum AuditLogStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum AuditRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  passwordHash      String?
  status            UserStatus         @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organizationUsers OrganizationUser[]
  auditLogs         AuditLog[]
  integrationContextPreferences UserIntegrationContextPreference[]
  productEnrichmentHistories ProductEnrichmentHistory[]

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Organization {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String?                   @unique
  document                 String?
  cnpj                     String?
  status                   OrganizationStatus        @default(ACTIVE)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  users                    OrganizationUser[]
  subscription             Subscription?
  blingConnections         BlingConnection[]
  erpConnections           ERPConnection[]
  mercadoLivreConnections  MercadoLivreConnection[]
  mercadoLivreListingCaches MercadoLivreListingCache[]
  mercadoLivreReferenceImports MercadoLivreReferenceImport[]
  productEnrichmentHistories ProductEnrichmentHistory[]
  marketplaceConnections   MarketplaceConnection[]
  marketplaceCategoryMappings MarketplaceCategoryMapping[]
  marketplaceProductAttributeValues MarketplaceProductAttributeValue[]
  oauthStates              OAuthState[]
  syncRules                SyncRule[]
  syncJobs                 SyncJob[]
  erpSyncJobs              ErpSyncJob[]
  products                 Product[]
  blingProductImportDrafts BlingProductImportDraft[]
  productEnrichmentDrafts  ProductEnrichmentDraft[]
  aiJobs                   AIJob[]
  productAISuggestions     ProductAISuggestion[]
  orders                   Order[]
  publicationQueue         PublicationQueue[]
  webhookEvents            WebhookEvent[]
  auditLogs                AuditLog[]
  usageCounters            UsageCounter[]
  notifications            Notification[]
  stockTransferRules       StockTransferRule[]
  stockTransferRuns        StockTransferRun[]
  userIntegrationContextPreferences UserIntegrationContextPreference[]

  @@index([createdAt])
  @@index([status])
}

model OrganizationUser {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role         @default(ADMIN)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
}

model Plan {
  id                   String         @id @default(cuid())
  code                 PlanCode       @unique
  name                 String
  blingLimit           Int
  operationLimit       Int
  maxBlingConnections  Int            @default(1)
  maxMonthlyOperations Int            @default(1000)
  maxUsers             Int            @default(3)
  features             Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @default(now()) @updatedAt
  subscriptions        Subscription[]
}

model Subscription {
  id                 String             @id @default(cuid())
  organizationId     String             @unique
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  enterpriseLimit    Int?
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime           @default(now())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan               Plan               @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([planId])
  @@index([status])
}

model BlingConnection {
  id                      String                   @id @default(cuid())
  organizationId          String
  name                    String
  role                    ConnectionRole
  status                  ConnectionStatus         @default(PENDING)
  environment             BlingEnvironment         @default(PRODUCTION)
  externalCompanyName     String?
  externalCompanyDocument String?
  externalCompanyId       String?
  externalAccountEmail    String?
  clientIdEncrypted       String?
  clientSecretEncrypted   String?
  internalNotes           String?
  scopes                  String?
  externalAccountId       String?
  isDefault               Boolean                  @default(false)
  selectedAt              DateTime?
  lastSyncAt              DateTime?
  lastProductSyncAt       DateTime?
  lastTestAt              DateTime?
  lastError               String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tokens                  BlingToken[]
  syncRules               SyncRule[]
  syncJobs                SyncJob[]
  mappings                ProductExternalMapping[]
  orderMappings           OrderExternalMapping[]
  inventory               InventoryBalance[]
  productImportDrafts     BlingProductImportDraft[]
  erpSyncJobs             ErpSyncJob[]
  userIntegrationContextPreferences UserIntegrationContextPreference[]

  @@index([organizationId])
  @@index([organizationId, role])
  @@index([organizationId, isDefault])
  @@index([selectedAt])
  @@index([status])
  @@index([createdAt])
}

model BlingToken {
  id                    String          @id @default(cuid())
  organizationId        String
  blingConnectionId     String          @map("connectionId")
  accessTokenEncrypted  String          @map("accessTokenEnc")
  refreshTokenEncrypted String          @map("refreshTokenEnc")
  tokenType             String          @default("Bearer")
  scope                 String?
  expiresAt             DateTime
  refreshExpiresAt      DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  connection            BlingConnection @relation(fields: [blingConnectionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([blingConnectionId])
  @@index([organizationId, blingConnectionId])
}

model MercadoLivreConnection {
  id                    String           @id @default(cuid())
  organizationId        String
  userId                String?
  name                  String           @default("Mercado Livre")
  accountAlias          String?
  clientId              String?
  clientSecretEncrypted String?
  redirectUri           String?
  siteId                String           @default("MLB")
  taxRate               Decimal?         @db.Decimal(5, 2)
  orderImportStartDate  DateTime?
  configStatus          String           @default("MISSING")
  status                ConnectionStatus @default(PENDING)
  externalUserId        String?
  sellerNickname        String?
  tokenType             String           @default("Bearer")
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  scope                 String?
  expiresAt             DateTime?
  isDefault             Boolean          @default(false)
  lastRefreshAt         DateTime?
  lastSyncAt            DateTime?
  lastError             String?
  connectedAt           DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listingCaches         MercadoLivreListingCache[]

  @@index([organizationId])
  @@index([organizationId, configStatus])
  @@index([userId])
  @@index([siteId])
  @@index([status])
  @@index([organizationId, isDefault])
  @@index([expiresAt])
  @@index([lastSyncAt])
  @@index([updatedAt])
}

model MercadoLivreListingCache {
  id                       String                 @id @default(cuid())
  organizationId           String
  mercadoLivreConnectionId String
  externalItemId           String
  title                    String
  sku                      String?
  gtin                     String?
  brand                    String?
  partNumber               String?
  categoryId               String?
  categoryName             String?
  price                    Decimal?               @db.Decimal(12, 2)
  currencyId               String?
  status                   String?
  permalink                String?
  thumbnail                String?
  rawAttributesJson        Json?
  lastSyncedAt             DateTime               @default(now())
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  organization             Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection               MercadoLivreConnection @relation(fields: [mercadoLivreConnectionId], references: [id], onDelete: Cascade)

  @@unique([mercadoLivreConnectionId, externalItemId])
  @@index([organizationId])
  @@index([mercadoLivreConnectionId])
  @@index([organizationId, mercadoLivreConnectionId])
  @@index([sku])
  @@index([gtin])
  @@index([title])
  @@index([categoryId])
  @@index([status])
  @@index([lastSyncedAt])
}

model MarketplaceConnection {
  id                    String              @id @default(cuid())
  organizationId        String
  userId                String?
  provider              MarketplaceProvider
  accountAlias          String
  status                String              @default("NOT_CONFIGURED")
  configStatus          String              @default("MISSING")
  credentialsEncrypted  String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenType             String?
  expiresAt             DateTime?
  scopes                String?
  externalAccountId     String?
  externalShopId        String?
  sellerId              String?
  siteId                String?
  region                String?
  marketplaceId         String?
  environment           String?
  taxRate               Decimal?            @db.Decimal(5, 2)
  orderImportStartDate  DateTime?
  internalNotes         String?
  connectedAt           DateTime?
  lastSyncAt            DateTime?
  lastConnectionTestAt  DateTime?
  lastError             String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([provider])
  @@index([status])
  @@index([configStatus])
  @@index([updatedAt])
}

model ERPConnection {
  id                       String                    @id @default(cuid())
  organizationId           String
  userId                   String?
  provider                 ERPProvider
  accountAlias             String
  status                   String                    @default("NOT_CONFIGURED")
  configStatus             String                    @default("MISSING")
  credentialsEncrypted     String?
  accessTokenEncrypted     String?
  refreshTokenEncrypted    String?
  tokenType                String?
  expiresAt                DateTime?
  scopes                   String?
  externalAccountId        String?
  externalCompanyId        String?
  environment              String?
  taxRate                  Decimal?                  @db.Decimal(5, 2)
  orderImportStartDate     DateTime?
  productSyncEnabled       Boolean                   @default(false)
  orderSyncEnabled         Boolean                   @default(false)
  stockSyncEnabled         Boolean                   @default(false)
  invoiceSyncEnabled       Boolean                   @default(false)
  internalNotes            String?
  connectedAt              DateTime?
  lastSyncAt               DateTime?
  lastConnectionTestAt     DateTime?
  lastError                String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  blingProductImportDrafts BlingProductImportDraft[]
  syncJobs                 ErpSyncJob[]

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([provider])
  @@index([status])
  @@index([configStatus])
  @@index([updatedAt])
}

model ErpSyncJob {
  id                    String        @id @default(cuid())
  organizationId        String
  erpConnectionId       String
  blingConnectionId     String?
  provider              ERPProvider
  type                  String
  status                String        @default("PENDING")
  totalFetched          Int           @default(0)
  totalCreatedDrafts    Int           @default(0)
  totalUpdatedDrafts    Int           @default(0)
  totalExistingProducts Int           @default(0)
  totalErrors           Int           @default(0)
  currentPage           Int           @default(1)
  lastCursor            String?
  startedAt             DateTime?
  finishedAt            DateTime?
  errorMessage          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  erpConnection         ERPConnection @relation(fields: [erpConnectionId], references: [id], onDelete: Cascade)
  blingConnection       BlingConnection? @relation(fields: [blingConnectionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([erpConnectionId])
  @@index([blingConnectionId])
  @@index([provider])
  @@index([type])
  @@index([status])
  @@index([updatedAt])
}

model OAuthState {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  provider       OAuthProvider  @default(BLING)
  stateHash      String         @unique
  connectionName String
  connectionRole ConnectionRole
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([provider])
  @@index([expiresAt])
  @@index([createdAt])
}

model SyncRule {
  id                    String           @id @default(cuid())
  organizationId        String
  connectionId          String?
  productsEnabled       Boolean          @default(true)
  pricesEnabled         Boolean          @default(true)
  inventoryEnabled      Boolean          @default(true)
  imagesEnabled         Boolean          @default(true)
  ordersEnabled         Boolean          @default(false)
  direction             SyncDirection
  conflictStrategy      ConflictStrategy
  safetyStock           Int              @default(0)
  preventNegativeStock  Boolean          @default(true)
  preserveBlockedFields Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection            BlingConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([connectionId])
}

model SyncJob {
  id             String           @id @default(cuid())
  organizationId String
  connectionId   String?
  type           String
  status         JobStatus        @default(PENDING)
  attempts       Int              @default(0)
  correlationId  String?
  lastError      String?
  createdAt      DateTime         @default(now())
  processedAt    DateTime?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection     BlingConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  events         SyncJobEvent[]

  @@index([organizationId])
  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
}

model SyncJobEvent {
  id             String   @id @default(cuid())
  organizationId String
  syncJobId      String
  level          String
  message        String
  safePayload    Json?
  createdAt      DateTime @default(now())
  syncJob        SyncJob  @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([syncJobId])
  @@index([createdAt])
}

model BlingProductImportDraft {
  id              String        @id @default(cuid())
  organizationId  String
  erpConnectionId String
  blingConnectionId String?
  externalId      String
  sku             String?
  gtin            String?
  name            String
  description     String?
  price           Decimal?      @db.Decimal(12, 2)
  costPrice       Decimal?      @db.Decimal(12, 2)
  stock           Int?
  unit            String?
  imageUrl        String?
  brand           String?
  category        String?
  ncm             String?
  supplierName    String?
  supplierCode    String?
  weight          Decimal?      @db.Decimal(10, 3)
  height          Decimal?      @db.Decimal(10, 3)
  width           Decimal?      @db.Decimal(10, 3)
  depth           Decimal?      @db.Decimal(10, 3)
  status          String?
  rawData         Json?
  importStatus    String        @default("PENDING")
  confidenceScore Int?
  lastFetchedAt   DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  erpConnection   ERPConnection @relation(fields: [erpConnectionId], references: [id], onDelete: Cascade)
  blingConnection BlingConnection? @relation(fields: [blingConnectionId], references: [id], onDelete: SetNull)

  @@unique([organizationId, blingConnectionId, externalId])
  @@index([organizationId])
  @@index([erpConnectionId])
  @@index([blingConnectionId])
  @@index([importStatus])
  @@index([sku])
  @@index([gtin])
  @@index([updatedAt])
  @@index([lastFetchedAt])
}

model Product {
  id               String                   @id @default(cuid())
  organizationId   String
  sku              String?
  ean              String?
  name             String
  description      String?
  category         String?
  brand            String?
  ncm              String?
  cest             String?
  status           String                   @default("DRAFT")
  enrichmentStatus String                   @default("IMPORTED")
  syncStatus       String                   @default("NOT_SYNCED")
  source           String?
  confidenceScore  Int                      @default(0)
  weight           Decimal?                 @db.Decimal(10, 3)
  height           Decimal?                 @db.Decimal(10, 3)
  width            Decimal?                 @db.Decimal(10, 3)
  depth            Decimal?                 @db.Decimal(10, 3)
  attributes       Json?
  blockedFields    Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  images           ProductImage[]
  mappings         ProductExternalMapping[]
  prices           ProductPrice[]
  priceHistory     ProductPriceHistory[]
  enrichmentDrafts ProductEnrichmentDraft[]
  aiJobs           AIJob[]
  aiSuggestions    ProductAISuggestion[]
  inventory        InventoryBalance[]
  movements        InventoryMovement[]
  orderItems       OrderItem[]
  marketplaceCategoryMappings MarketplaceCategoryMapping[]
  marketplaceProductAttributeValues MarketplaceProductAttributeValue[]
  mercadoLivreReferenceImports MercadoLivreReferenceImport[]
  productEnrichmentHistories ProductEnrichmentHistory[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([sku])
  @@index([ean])
  @@index([status])
  @@index([enrichmentStatus])
  @@index([syncStatus])
  @@index([createdAt])
}

model MercadoLivreReferenceImport {
  id                String       @id @default(cuid())
  organizationId    String
  productId         String?
  source            String       @default("MERCADO_LIVRE")
  externalItemId    String
  title             String?
  description       String?
  gtin              String?
  brand             String?
  partNumber        String?
  categoryId        String?
  categoryName      String?
  price             Decimal?     @db.Decimal(12, 2)
  currencyId        String?
  permalink         String?
  thumbnail         String?
  picturesJson      Json?
  attributesJson    Json?
  rawSanitizedJson  Json?
  status            String       @default("DRAFT")
  createdByUserId   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product           Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([productId])
  @@index([externalItemId])
  @@index([organizationId, externalItemId])
  @@index([status])
  @@index([createdAt])
}

model ProductEnrichmentHistory {
  id                              String       @id @default(cuid())
  organizationId                  String
  productId                       String
  userId                          String?
  sourceProvider                  String       @default("MERCADO_LIVRE")
  sourceExternalId                String?
  sourceUrl                       String?
  compatibilityLevel              String?
  compatibilityScore              Int?
  confirmationMainUsed            Boolean      @default(false)
  confirmationLowCompatibilityUsed Boolean     @default(false)
  fieldsChangedJson               Json
  oldValuesJson                   Json
  newValuesJson                   Json
  createdAt                       DateTime     @default(now())
  organization                    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product                         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user                            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([productId])
  @@index([userId])
  @@index([sourceProvider])
  @@index([sourceExternalId])
  @@index([compatibilityLevel])
  @@index([createdAt])
}

model MarketplaceCategoryMapping {
  id                      String                    @id @default(cuid())
  organizationId          String
  productId               String?
  internalGtinCatalogId   String?
  provider                MarketplaceCategoryProvider
  marketplaceCategoryId   String?
  marketplaceCategoryName String?
  marketplaceCategoryPath String?
  confidenceScore         Int?
  source                  MarketplaceCategorySource @default(MANUAL)
  status                  MarketplaceCategoryStatus @default(SUGGESTED)
  requiredAttributes      Json?
  metadata                Json?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  organization            Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product                 Product?                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  internalGtinCatalog     InternalGtinCatalog?      @relation(fields: [internalGtinCatalogId], references: [id], onDelete: SetNull)
  productAttributeValues  MarketplaceProductAttributeValue[]

  @@unique([organizationId, productId, provider])
  @@index([organizationId])
  @@index([productId])
  @@index([internalGtinCatalogId])
  @@index([provider])
  @@index([status])
  @@index([updatedAt])
}

model MarketplaceProductAttributeValue {
  id                    String                            @id @default(cuid())
  organizationId        String
  productId             String
  mappingId             String
  provider              MarketplaceCategoryProvider
  marketplaceCategoryId String
  attributeId           String
  attributeName         String
  value                 String?
  valueId               String?
  source                MarketplaceProductAttributeSource @default(MANUAL)
  status                MarketplaceProductAttributeStatus @default(EMPTY)
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt
  organization          Organization                      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product               Product                           @relation(fields: [productId], references: [id], onDelete: Cascade)
  mapping               MarketplaceCategoryMapping        @relation(fields: [mappingId], references: [id], onDelete: Cascade)

  @@unique([mappingId, attributeId])
  @@index([organizationId])
  @@index([productId])
  @@index([mappingId])
  @@index([provider])
  @@index([marketplaceCategoryId])
  @@index([attributeId])
  @@index([status])
  @@index([updatedAt])
}

model MarketplaceCategoryCatalog {
  id                          String                      @id @default(cuid())
  provider                    MarketplaceCategoryProvider
  siteId                      String?
  marketplaceCategoryId       String
  name                        String
  path                        String
  parentMarketplaceCategoryId String?
  isLeaf                      Boolean                     @default(false)
  level                       Int?
  attributesJson              Json?
  rawJson                     Json?
  lastSyncedAt                DateTime?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt

  @@unique([provider, marketplaceCategoryId])
  @@index([provider])
  @@index([siteId])
  @@index([parentMarketplaceCategoryId])
  @@index([name])
  @@index([path])
  @@index([lastSyncedAt])
}

model InternalGtinCatalog {
  id                   String   @id @default(cuid())
  gtin                 String
  normalizedGtin       String   @unique
  title                String
  optimizedTitle       String
  brand                String?
  category             String?
  descriptionShort     String?
  descriptionFull      String?
  technicalDescription String?
  imageUrl             String?
  unit                 String?
  ncm                  String?
  weight               Decimal? @db.Decimal(10, 3)
  height               Decimal? @db.Decimal(10, 3)
  width                Decimal? @db.Decimal(10, 3)
  depth                Decimal? @db.Decimal(10, 3)
  attributesJson       Json?
  imagesJson           Json?
  metadataJson         Json?
  source               String?
  sourceUrl            String?
  confidenceScore      Int      @default(0)
  approved             Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  marketplaceCategoryMappings MarketplaceCategoryMapping[]

  @@index([gtin])
  @@index([normalizedGtin])
  @@index([approved])
  @@index([confidenceScore])
  @@index([updatedAt])
}

