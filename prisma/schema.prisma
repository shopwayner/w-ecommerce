model Order {
  id                 String                 @id @default(cuid())
  organizationId     String
  number             String
  orderNumber        String?
  sourceProvider     String                 @default("MANUAL")
  sourceConnectionId String?
  externalOrderId    String?
  customerName       String
  customerDocument   String?
  customerEmail      String?
  customerPhone      String?
  channel            String?
  status             String
  externalStatusCode String?
  externalStatusName String?
  orderSituationId   String?
  orderSituationName String?
  paymentStatus      String?
  shippingStatus     String?
  invoiceStatus      String?
  invoiceNumber      String?
  invoiceKey         String?
  invoiceExternalId  String?
  invoiceIssuedAt    DateTime?
  lastStatusSyncAt   DateTime?
  statusSyncWarnings Json?
  total              Decimal                @db.Decimal(12, 2)
  totalAmount        Decimal                @default(0) @db.Decimal(12, 2)
  currency           String                 @default("BRL")
  orderedAt          DateTime?
  importedAt         DateTime?
  rawJson            Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items              OrderItem[]
  mappings           OrderExternalMapping[]

  @@unique([organizationId, number])
  @@unique([organizationId, sourceProvider, sourceConnectionId, externalOrderId])
  @@index([organizationId])
  @@index([sourceProvider])
  @@index([sourceConnectionId])
  @@index([externalOrderId])
  @@index([status])
  @@index([externalStatusCode])
  @@index([orderSituationId])
  @@index([paymentStatus])
  @@index([shippingStatus])
  @@index([invoiceStatus])
  @@index([createdAt])
  @@index([orderedAt])
}

model OrderItem {
  id                String   @id @default(cuid())
  organizationId    String
  orderId           String
  productId         String?
  externalProductId String?
  sku               String?
  name              String   @default("")
  quantity          Int
  unitPrice         Decimal  @db.Decimal(12, 2)
  totalPrice        Decimal  @default(0) @db.Decimal(12, 2)
  rawJson           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product? @relation(fields: [productId], references: [id])

  @@index([organizationId])
  @@index([orderId])
  @@index([productId])
  @@index([externalProductId])
  @@index([sku])
}

